<script src="~/Areas/Common/js/Services/CommonService.js"></script>
<script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>
<script src="~/Areas/SetUp/js/Controller/ChargeHeaderController.js"></script>
<script>

    $(document).ready(function () {
        $('.productsave').off('click').on('click', function () {
            var getId = $("#Id").val() || 0;
            var status = "Update";
            Confirmation(
                "Are you sure you want to " + status + " this entry?",
                function (result) {
                    if (result) {
                        Update();
                    }
                });
        });

        function Update() {
            debugger;
            var validator = $("#productFrmEntry").validate();
            var isValid = validator.form();
            if (!isValid) {
                validator.focusInvalid();
                return;
            }
            debugger;
            // This gives you ONLY ChargeDetailVM fields
            var detail = serializeInputs("productFrmEntry");

            console.log("Detail:", detail);

            // 🔥 Wrap into ChargeHeaderVM
            var model = {
      
                Id: detail.ChargeHeaderId || 0,   // or header id from hidden field if exists
                ChargeGroup: detail.ChargeGroup || null,
                ChargeGroupId: detail.ChargeGroupId || null,
                Operation: "update",
                IsHeaderUpdate: false,

                // ✅ IMPORTANT: list wrapper
                ChargeDetails: [
                    {
                        Id: detail.Id || 0,
                        Code: detail.Code,
                        Name: detail.Name,
                        ProductGroupName: detail.ProductGroupName,
                        ConversionFactor: detail.ConversionFactor,
                        ChargeHeaderId: detail.ChargeHeaderId,
                        ProductId: detail.ProductId,
                        ProductName: detail.ProductName,
                        ChargeGroupId: detail.ChargeGroupId,
                        ChargeGroup: detail.ChargeGroup,

                        CIFCharge: detail.CIFCharge,
                        ExchangeRateUsd: detail.ExchangeRateUsd,
                        InsuranceRate: detail.InsuranceRate,
                        BankCharge: detail.BankCharge,
                        OceanLoss: detail.OceanLoss,
                        CPACharge: detail.CPACharge,
                        HandelingCharge: detail.HandelingCharge,
                        LightCharge: detail.LightCharge,
                        Survey: detail.Survey,
                        CostLiterExImport: detail.CostLiterExImport,
                        ExERLRate: detail.ExERLRate,
                        DutyPerLiter: detail.DutyPerLiter,
                        Refined: detail.Refined,
                        Crude: detail.Crude,
                        SDRate: detail.SDRate,
                        DutyInTariff: detail.DutyInTariff,
                        ATRate: detail.ATRate,
                        AITRate: detail.AITRate,
                        VATRate: detail.VATRate,
                        ConversionFactorFixedValue: detail.ConversionFactorFixedValue,
                        VATRateFixed: detail.VATRateFixed,
                        RiverDues: detail.RiverDues,

                        TariffRate: detail.TariffRate,
                        FobPriceBBL: detail.FobPriceBBL,
                        FreightUsd: detail.FreightUsd,
                        ServiceCharge: detail.ServiceCharge,
                        ProcessFee: detail.ProcessFee,
                        RcoTreatmentFee: detail.RcoTreatmentFee,
                        AbpTreatmentFee: detail.AbpTreatmentFee,

                        ProcessFeeRate: detail.ProcessFeeRate,
                        RcoTreatmentFeeRate: detail.RcoTreatmentFeeRate,
                        AbpTreatmentFeeRate: detail.AbpTreatmentFeeRate,
                        ProductImprovementFee: detail.ProductImprovementFee
                    }
                ]
            };

            console.log("Final Model:", model);

            var url = "/SetUp/ChargeHeader/CreateEdit";

            CommonAjaxService.finalSave(url, model, saveDone, saveFail
            );
        }
        function saveDone(result) {
            debugger;
            console.log(result);
            if (result.Status == 200) {
                ShowNotification(1, result.Message);
                if (result.Data != null) {
                    $("#Id").val(result.Data.Id);
                }

                $("#Operation").val("update");
                $(".divSave").hide();
                $(".divUpdate").show();
            }
            else {

                ShowNotification(3, result.Message);
            }

        }

        function saveFail(result) {
            console.log(result);
            ShowNotification(3, "Query Exception!");

        };

    });

</script>




