                @Html.Hidden("detailsListJson", JsonConvert.SerializeObject(Model.ApprovalOrganogramDetails ?? new List<ShampanBFRS.Models.SetUpVMs.ApprovalOrganogramDetailVM>()))

                <div class="form-group row">



                    <div class="col-sm-2">
                        @Html.LabelFor(model => model.Module)
                        <div class="input-group">
                            @Html.TextBoxFor(model => model.Module, new { placeholder = "Enter Module", @class = "required form-control form-control-sm" })
                        </div>

                        <span id="titleError2" class="text-danger" style="display:none;"></span>

                    </div>

                    @*<div class="col-sm-2">
                @Html.LabelFor(model => model.TransactionType)
