@using Newtonsoft.Json
@model ShampanBFRS.Models.Ceiling.BudgetOtherDepartmentHeaderVM

@{
    ViewBag.Title = "Initial Budget";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div id="tabs">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    @if (Model.Operation == "add")
                    {
                        <h1 class="m-0">Initial Budget Create(@Model.BudgetType)</h1>
                    }
                    else
                    {
                        <h1 class="m-0">Initial Budget Edit(@Model.BudgetType)</h1>
                    }
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li id="btnBack"><img src="~/Content/css/ButtonsIcons/back-icon.png" title="Click for Go Back" /></li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header p-2">


            @if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
            {
                <button type="button" id="btnApprove" class="button btnsave sslUpdate">Approve</button>
                <button type="button" id="btnReject" class="button btnPost sslPost">Reject</button>

            }
            else
            {
                <button type="button" id="btnApprove" class="button btnsave sslUpdate">Approve</button>
                <button type="button" id="btnReject" class="button btnPost sslPost">Reject</button>

            }

        </div>

    </div>

    <div class="container-fluid">
        <div class="mt-3">
            <div id="tabs-1">
                <form id="frmEntry">
                    <div class="card card-secondary">
                        <div class="card-header">
                            <h3 class="card-title"> Initial Budget Info</h3>
                        </div>
                        <div class="card-body">
                            @Html.HiddenFor(model => model.Id)
                            @Html.HiddenFor(model => model.Operation)
                            @Html.HiddenFor(model => model.TransactionType)
                            @Html.HiddenFor(model => model.BudgetType)
                            @Html.HiddenFor(model => model.BudgetSetNo)
                            @Html.Hidden("SelectedFiscalYearId", Model.FiscalYearId)
                            @Html.Hidden("detailsListJson", JsonConvert.SerializeObject(Model.detailList ?? new List<ShampanBFRS.Models.Ceiling.BudgetOtherDepartmentDetailVM>()))

                            <div class="form-group row">

                                @if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
                                {

                                    <div class="col-sm-2">
                                        @Html.LabelFor(model => model.Code)
                                        <div style="display: flex; align-items: center;">
                                            <span id="btnPrevious" class="fa fa-backward" style="color: darkseagreen;"></span>&nbsp;
                                            @Html.TextBoxFor(model => model.Code, new { placeholder = "Code Auto Generate", @class = " csCode  form-control form-control-sm", @readonly = "readonly", @style = "width:140px;" }) &nbsp;
                                            <span id="btnNext" class="fa fa-forward" style="color: darkseagreen;"></span>
                                        </div>
                                    </div>

                                    <div class="col-sm-2">
                                        @Html.LabelFor(model => model.FiscalYearId)
                                        <div class="input-group">
                                            @Html.TextBoxFor(model => model.FiscalYearId, new { placeholder = "Enter Fiscal Year", @class = "form-control form-control-sm", @readonly = "readonly" })
                                        </div>
                                        @Html.ValidationMessageFor(model => model.FiscalYearId)
                                    </div>

                                }
                                else
                                {

                                    <div class="col-sm-2">
                                        @Html.LabelFor(model => model.Code)
                                        <div style="display: flex; align-items: center;">
                                            <span id="btnPrevious" class="fa fa-backward" style="color: darkseagreen;"></span>&nbsp;
                                            @Html.TextBoxFor(model => model.Code, new { placeholder = "Code Auto Generate", @class = " csCode  form-control form-control-sm", @readonly = "readonly", @style = "width:140px;" }) &nbsp;
                                            <span id="btnNext" class="fa fa-forward" style="color: darkseagreen;"></span>
                                        </div>
                                    </div>

                                    <div class="col-sm-2">
                                        @Html.LabelFor(model => model.FiscalYearId)
                                        <div class="input-group">
                                            @Html.TextBoxFor(model => model.FiscalYearId, new { placeholder = "Enter Fiscal Year", @class = "required form-control form-control-sm", @readonly = "readonly" })
                                        </div>
                                        <span id="titleError2" class="text-danger" style="display:none;"></span>
                                    </div>
                                }

                                @*<div class="col-sm-1">
                                    <div class="input-group">
                                        <button type="button" title="Load" class="btn btn-primary btn-sm sslLoad btnLoad"
                                                style="margin-top: 26%;" id="btnFDt">
                                            Load
                                        </button>
                                    </div>
                                </div>*@


                            </div>

                        </div>

                    </div>

                    @if (Model.Operation.Equals("add", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="card card-secondary">
                            <div class="card-header">
                                <h3 class="card-title">
                                    Details
                                </h3>
                            </div>
                            <div class="card-body">
                                <div id="BudgetDetailsData"></div>
                            </div>
                        </div>
                    }
                    @if (Model.Operation.Equals("update", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="card card-secondary">
                            <div class="card-header">
                                <h3 class="card-title">
                                    Details
                                </h3>
                            </div>
                            <div class="card-body">
                                <div id="updtBudgetDetailsData"></div>
                            </div>
                        </div>
                    }

                </form>


                <div class="card card-secondary auditcard">

                    <div class="card-header">
                        <h3 class="card-title">Audit Details</h3>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-2">
                                <div class="row">
                                    @Html.Label("Type")
                                </div>
                            </div>
                            <div class="col-sm-10">
                                <div class="row">
                                    <div class="col-sm-3">
                                        @Html.Label("Created")
                                    </div>
                                    <div class="col-sm-3">
                                        @Html.Label("Updated")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-2">
                                <div class="row">
                                    <div class="col-sm-12">
                                        @Html.Label("By")<br /><div class="clearfix">&nbsp;</div>
                                        @Html.Label("On")<br /><div class="clearfix">&nbsp;</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-10">

                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="~/Areas/Common/js/Services/CommonService.js"></script>
    <script src="~/Areas/Common/js/Services/CommonAjaxService.js"></script>
    <script src="~/Areas/Common/js/Services/CommonValidationHelper.js"></script>
    <script src="~/Areas/Ceiling/js/Controllers/ApprovalController.js"></script>
    <script>
        $(document).ready(function () {
            ApprovalController.init();
        });
    </script>

}



